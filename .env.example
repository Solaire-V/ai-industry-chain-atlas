ATLAS_DATA_SOURCE=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public client keys are optional. Do not use them for server-side writes.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Protected market refresh endpoint. Vercel Cron convention uses CRON_SECRET.
CRON_SECRET=
# Optional project-specific extra secret. Either CRON_SECRET or ATLAS_CRON_SECRET can authorize refresh.
ATLAS_CRON_SECRET=

MARKET_DATA_PROVIDER=disabled
# A-share primary provider candidate: hithink-fuyao
HITHINK_FUYAO_API_KEY=
# Compatibility aliases accepted by the provider selector.
FUYAO_TOKEN=
API_KEY=

MARKET_DATA_API_KEY=
